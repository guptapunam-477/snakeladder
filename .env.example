# Copy this file to ".env" and fill in values from your Firebase project.
# (Firebase Console -> Project settings -> General -> Your apps -> Web app -> SDK setup and configuration)
#
# These are PUBLIC client keys. It is normal for them to ship in the browser bundle.
# Your data is protected by Firestore Security Rules, NOT by hiding these keys.
#
# In Netlify, add each of these under: Site settings -> Environment variables.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
