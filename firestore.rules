rules_version = '2';

// ---------------------------------------------------------------------------
// Chaos Ladder — Firestore Security Rules
//
// Design note: the entire game lives in a single document, rooms/{code}, and
// all mutations go through client-side Firestore TRANSACTIONS that re-validate
// game state (whose turn it is, who the host is, etc.). Reproducing the full
// game rules in Firestore's rules language is impractical, so these rules:
//   * require an authenticated (anonymous) user — blocks anonymous internet
//     scrapers / random writers,
//   * scope all access to the `rooms` collection,
//   * sanity-check the shape of new room documents,
//   * cap the player count so a malicious client can't balloon the doc.
//
// This is appropriate for a casual, invite-by-code party game. For a hardened,
// competitive deployment see the "Stricter rules" section in README.md, which
// moves authoritative moves into Cloud Functions.
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{code} {

      // Must be signed in (anonymous auth is fine) to read a room.
      allow read: if request.auth != null;

      // Creating a new room: must look like a fresh, valid room.
      allow create: if request.auth != null
        && request.resource.data.code is string
        && request.resource.data.status == 'waiting'
        && request.resource.data.players is list
        && request.resource.data.players.size() >= 1
        && request.resource.data.players.size() <= 5
        && request.resource.data.board is list;

      // Updating an existing room (joins, rolls, votes, etc.). We keep this
      // permissive but bounded: signed in, the code can't change, and the
      // player list can never exceed the maximum.
      allow update: if request.auth != null
        && request.resource.data.code == resource.data.code
        && request.resource.data.players is list
        && request.resource.data.players.size() <= 5;

      // No client deletes — rooms simply go stale. (Optionally add a TTL or a
      // scheduled Cloud Function cleanup; see README.)
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
